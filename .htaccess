# ─────────────────────────────────────────────────
# Samburu EWS — Public .htaccess
# Apache 2.4+  ·  Requires mod_rewrite, mod_headers
# ─────────────────────────────────────────────────

# Deny direct access to application directories
# (these folders must live OUTSIDE public/ in production,
#  but this protects them if accidentally exposed)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to /app, /migrations, /docs
    RewriteRule ^\.\./(app|migrations|docs)(/|$) - [F,L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Default charset
AddDefaultCharset UTF-8
